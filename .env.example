# ══════════════════════════════════════════════════════════════════
# Supply Chain Alpha — Environment Configuration
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required: LLM provider (at minimum)
# Optional: FRED + SEC for richer analysis

# ── LLM Provider ──────────────────────────────────────────────────
# "openrouter" = cloud API (dev mode, fast iteration)
# "ollama"     = local Ollama server (production, $0/month)
LLM_PROVIDER=openrouter

# ── OpenRouter (required if LLM_PROVIDER=openrouter) ──────────────
# Get a free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Ollama (optional, defaults to localhost) ──────────────────────
# Only needed if Ollama runs on a different host/port
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Model Override (optional) ─────────────────────────────────────
# Default: GLM-4.7-Flash on both providers
# OpenRouter model name: z-ai/glm-4.7-flash
# Ollama model name: glm4
# REASONING_MODEL=z-ai/glm-4.7-flash
# FAST_MODEL=z-ai/glm-4.7-flash

# ── FRED Macroeconomic Data (optional, enriches analysis) ─────────
# Free key from: https://fred.stlouisfed.org/docs/api/api_key.html
# Without this, the pipeline still works but skips macro indicators
FRED_API_KEY=your_fred_api_key_here

# ── SEC EDGAR (optional, enables SEC filing extraction) ───────────
# SEC requires an email in the User-Agent header. No account needed.
# Without this, SEC filings will be skipped.
SEC_EDGAR_EMAIL=your_email@example.com

# ── Langfuse Observability (optional — LLM tracing dashboard) ────
# Sign up free at: https://cloud.langfuse.com
# Create a project → Settings → API Keys → copy both keys
LANGFUSE_PUBLIC_KEY=your_public_key_here
LANGFUSE_SECRET_KEY=your_secret_key_here
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ── Token Budget (optional) ──────────────────────────────────────
# Max characters for assembled LLM prompts (prevents silent truncation)
# MAX_PROMPT_CHARS=30000